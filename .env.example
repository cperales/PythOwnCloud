# PythOwnCloud — copy to .env and fill in real values
# WARNING: Never use these placeholder values in production. Change every value below.

# Secret API key for curl/script access
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POC_API_KEY=REPLACE_WITH_RANDOM_API_KEY

# Host directory to mount as storage (mapped to /data inside the container)
POC_DATA_FOLDER=/mnt/external-disk/pythowncloud-data

# Storage path inside the container (usually no need to change)
POC_STORAGE_PATH=/data

# Database directory (can be on faster storage like SD card, defaults to storage path)
POC_DB_PATH_DIR=/var/lib/pythowncloud

# scrypt hash of the web UI login password (also used for WebDAV Basic Auth)
# Generate: python3 -c "from pythowncloud.passwords import hash_password; print(hash_password('yourpassword'))"
POC_LOGIN_PASSWORD_HASH=REPLACE_WITH_GENERATED_HASH

# Session TTL in days (default: 7)
POC_SESSION_TTL_DAYS=7

# Set to true if the server is behind an HTTPS reverse proxy (adds Secure flag to session cookie)
POC_SESSION_COOKIE_SECURE=false

# S3-compatible API credentials
# Generate secret: python3 -c "import secrets; print(secrets.token_hex(32))"
POC_S3_ACCESS_KEY=pythowncloud
POC_S3_SECRET_KEY=REPLACE_WITH_RANDOM_S3_SECRET
