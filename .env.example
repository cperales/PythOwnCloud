# PythOwnCloud — copy to .env and fill in real values

# Secret API key for curl/script access
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POC_API_KEY=a1b2c3d4

# Storage path inside the container (usually no need to change)
POC_STORAGE_PATH=/data

# PostgreSQL connection string
POC_DB_URL=postgresql://poc:changeme@localhost:5432/pythowncloud

# bcrypt hash of the web UI login password
# Generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
POC_LOGIN_PASSWORD_HASH=$2b$12$changeme

# Session TTL in days (default: 7)
POC_SESSION_TTL_DAYS=7

# PostgreSQL password (used by docker-compose.yml)
DB_PASSWORD=changeme
